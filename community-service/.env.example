# Community service environment (local Docker)
# Copy to .env — never commit secrets

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,app

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://community:community@db:5432/community

# --- Redis (Channels + Celery) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- AWS / S3 events ---
AWS_REGION=us-east-1
NURTURE_EVENTS_BUCKET=nurture-events-dev-886436941204
EVENTS_USE_LOCAL=true
# SERVER_AWS_ACCESS_KEY_ID=
# SERVER_AWS_SECRET_ACCESS_KEY=

# --- Auth (reuse platform Cognito) ---
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
JWT_DEV_BYPASS=true

# --- Feature flags ---
ENABLE_COMMUNITIES=true
ENABLE_GROUP_CHAT=true
ENABLE_COHORTS=false
ENABLE_AI=false

# --- AI (Sprint 5+) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://dev.d9588bqvrp5xs.amplifyapp.com
