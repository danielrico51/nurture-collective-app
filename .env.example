# eGift cards — Stripe checkout + QuickBooks Sales Receipt on payment (server-only unless noted)
# GIFT_CARD_PAYMENT_PROVIDER=stripe
# GIFT_CARD_ORDER_WEBHOOK_URL=
# GIFT_CARD_ORDER_WEBHOOK_SECRET=
# eGift delivery — SES (production) with Resend Plan B while SES sandbox appeal is pending
# GIFT_CARD_EMAIL_ENABLED=true
# GIFT_CARD_EMAIL_PROVIDER=auto
# auto = try SES, fall back to Resend | ses = AWS only | resend = Resend only
# GIFT_CARD_EMAIL_FROM=info@nesting-place.com
# GIFT_CARD_EMAIL_FROM_NAME=The Nesting Place
# GIFT_CARD_FULFILLMENT_EMAIL=info@nesting-place.com
# GIFT_CARD_EMAIL_REPLY_TO=info@nesting-place.com
# RESEND_API_KEY=re_...
# Cognito verification emails (interim until SES production): npm run setup:cognito-resend-email
# See docs/platform/cognito-verification-email.md
# NEXT_PUBLIC_GIFT_CARD_PAYMENTS_ENABLED=true
# NEXT_PUBLIC_GIFT_CARD_PAYMENT_PROVIDER=stripe
# Stripe (required when GIFT_CARD_PAYMENT_PROVIDER=stripe)
# Set in Amplify via: ./infrastructure/aws/scripts/set-amplify-stripe-env.sh
# STRIPE_SECRET_KEY=sk_live_...   # or rk_live_... (Checkout Sessions read+write)
# STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe webhook endpoint: https://<your-domain>/api/webhooks/stripe
# QBO_DEFAULT_ITEM_ID=  (service item for gift card line on sales receipts)

# Billing + QuickBooks Online — purchases, CRM service invoices (server-only)
# CRM QuickBooks invoices require BILLING_SYNC_MODE=direct (or hybrid).
# BILLING_SYNC_MODE=direct
# BILLING_PAYMENT_PROVIDER=stub
# BILLING_S3_BUCKET=
# BILLING_USE_LOCAL_STORAGE=true
# N8N_BILLING_WEBHOOK_URL=
# N8N_BILLING_WEBHOOK_SECRET=
# NEXT_PUBLIC_BILLING_PAYMENTS_ENABLED=false
# NEXT_PUBLIC_BILLING_PAYMENT_PROVIDER=stub
