# AWS Cognito (from `npx ampx sandbox` or Amplify console after deploy)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# Management task board (S3 JSON storage)
TASKS_S3_BUCKET=nurture-collective-tasks

# Member intake profiles (S3 JSON storage — defaults to local .data/ in dev)
# INTAKE_S3_BUCKET=nurture-collective-tasks
# INTAKE_S3_KEY=management/intake.json
# INTAKE_USE_LOCAL_STORAGE=true
# Optional: defaults to management/tasks.json
# TASKS_S3_KEY=management/tasks.json
# Optional: defaults to admin if unset
MANAGEMENT_COGNITO_GROUP=admin
# Required at build time for client nav gating (must match MANAGEMENT_COGNITO_GROUP)
NEXT_PUBLIC_MANAGEMENT_COGNITO_GROUP=admin

# Amplify SSR server credentials (custom names — Amplify blocks AWS_* prefix)
# Create an IAM user with S3 + Cognito ListUsers, then set in Amplify env + .env.local
# SERVER_AWS_ACCESS_KEY_ID=
# SERVER_AWS_SECRET_ACCESS_KEY=

# Public integrations (client-safe)
NEXT_PUBLIC_CALENDLY_URL=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=hello@nurturecollective.com

# n8n automation webhooks (server-only)
N8N_INQUIRY_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_TASK_SYNC_WEBHOOK_URL=
N8N_CALENDLY_WEBHOOK_URL=

# Calendly webhook verification (server-only)
CALENDLY_WEBHOOK_SIGNING_KEY=

# Google reviews — placeholder until Google Business Profile is acquired
# Visibility: off | admin (team preview) | public
NEXT_PUBLIC_GOOGLE_REVIEWS_VISIBILITY=admin
# Mode: placeholder | live (server-only; live requires keys below)
GOOGLE_REVIEWS_MODE=placeholder
# After acquisition — Google Business Profile
GOOGLE_PLACE_ID=
GOOGLE_PLACES_API_KEY=
# Optional public link for "See all reviews on Google"
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=
