# GOOGLE_TASKS_IMPERSONATE_SERVICE_ACCOUNT=nurture-tasks-sync@boxwood-magnet-498623-n4.iam.gserviceaccount.com
# Amplify only — paste ADC from gcloud auth application-default login:
# GOOGLE_TASKS_ADC_JSON=
