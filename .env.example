# AWS Cognito (from `npx ampx sandbox` or Amplify console after deploy)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# Social sign-in (Google, Facebook, Apple) — Cognito Hosted UI + identity providers
# See docs/platform/social-auth-setup.md
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_COGNITO_DOMAIN=us-east-1ruftimytf.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_SOCIAL_AUTH_ENABLED=true
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
# NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=true
# NEXT_PUBLIC_AUTH_APPLE_ENABLED=true  # Requires Sign in with Apple in Cognito

# Dev only — allow /intake without Cognito (NEVER true in production)
# NEXT_PUBLIC_INTAKE_PUBLIC=true
# INTAKE_PUBLIC=true

# Management task board (S3 JSON storage — legacy admin tasks + current intake migration)
TASKS_S3_BUCKET=nurture-collective-tasks

# Blog posts (JSON document in tasks bucket by default)
# BLOG_S3_BUCKET=nurture-collective-tasks
# BLOG_S3_KEY=management/blog/posts.json
# BLOG_USE_LOCAL_STORAGE=true

# Events & classes (JSON document in tasks bucket by default)
# EVENTS_S3_BUCKET=nurture-collective-tasks
# EVENTS_S3_KEY=management/events/items.json
# EVENTS_USE_LOCAL_STORAGE=true

# Platform S3 buckets (from infrastructure/aws CloudFormation — see docs/platform/)
# NURTURE_LEADS_BUCKET=nurture-leads-dev-ACCOUNT_ID
# LEADS_USE_LOCAL_STORAGE=true   # force local .data/ lead storage
# LEADS_USE_S3=true              # opt into S3 lead storage during local dev
# NURTURE_CLIENTS_BUCKET=nurture-clients-dev-ACCOUNT_ID
# NURTURE_EVENTS_BUCKET=nurture-events-dev-ACCOUNT_ID
# NURTURE_CONTRACTS_BUCKET=nurture-contracts-dev-ACCOUNT_ID
# NURTURE_PROPOSALS_BUCKET=nurture-proposals-dev-ACCOUNT_ID
# NURTURE_NOTIFICATIONS_BUCKET=nurture-notifications-dev-ACCOUNT_ID
# NURTURE_ANALYTICS_BUCKET=nurture-analytics-dev-ACCOUNT_ID

# Django platform API (backend/) — optional in Sprint 1
# PLATFORM_API_URL=http://localhost:8000/api/v1

# Community service (community-service/) — member app proxy (server-side)
COMMUNITY_API_URL=http://localhost:8001
# Post feed scope: dev | staging | production (use dev locally so test posts stay off prod)
COMMUNITY_ENV_SCOPE=dev
NEXT_PUBLIC_COMMUNITY_ENV_SCOPE=dev
# Browser WebSocket base (optional; defaults to localhost:8001 in dev)
# NEXT_PUBLIC_COMMUNITY_API_URL=http://localhost:8001
# Set to false to disable example communities when the service is offline
# COMMUNITY_DEMO_FALLBACK=false
# Community media (post images + profile avatars):
#   - Local dev: stored under .data/ (served via /api/community/media/… and /api/account/avatar/…)
#   - Production: set an S3 bucket below (falls back to TASKS_S3_BUCKET if unset)
# COMMUNITY_MEDIA_S3_BUCKET=nurture-collective-tasks
# Post photos are stored under .data/community-post-images/ in local dev (served via /api/community/media/…)
# community-service/.env must use the same pool/client when validating Cognito:
#   COGNITO_USER_POOL_ID=${NEXT_PUBLIC_USER_POOL_ID}
#   COGNITO_USER_POOL_CLIENT_ID=${NEXT_PUBLIC_USER_POOL_CLIENT_ID}
#   JWT_DEV_BYPASS=true   # local only

# Member intake profiles (partitioned S3 JSON — defaults to local .data/ in dev)
# INTAKE_S3_BUCKET=nurture-collective-tasks
# Intake partition layout:
#   management/process=intake/user=<cognito-sub>/status=<status>/intake.json
# Conversation partition layout:
#   management/process=conversation/user=<cognito-sub>/session=<session-id>/conversation.json
# Legacy aggregate index (dual-written for backwards compatibility):
#   management/intake.json
# INTAKE_USE_LOCAL_STORAGE=true
# Set INTAKE_LEGACY_INDEX=false to stop updating management/intake.json
# Optional: defaults to management/tasks.json
# TASKS_S3_KEY=management/tasks.json
# Optional: defaults to admin if unset
MANAGEMENT_COGNITO_GROUP=admin
# Required at build time for client nav gating (must match MANAGEMENT_COGNITO_GROUP)
NEXT_PUBLIC_MANAGEMENT_COGNITO_GROUP=admin

# Amplify SSR server credentials (custom names — Amplify blocks AWS_* prefix)
# Create an IAM user with S3 + Cognito ListUsers, then set in Amplify env + .env.local
# SERVER_AWS_ACCESS_KEY_ID=
# SERVER_AWS_SECRET_ACCESS_KEY=

# Booking / scheduling — provider: auto | calendly | google
# auto prefers Google when NEXT_PUBLIC_GOOGLE_BOOKING_URL is set, else Calendly
NEXT_PUBLIC_BOOKING_PROVIDER=auto
# Calendly (interim / fallback)
NEXT_PUBLIC_CALENDLY_URL=
# Google Workspace appointment schedule — public booking page URL (fallback embed)
# Example: https://calendar.google.com/calendar/appointments/AcZssZ...
NEXT_PUBLIC_GOOGLE_BOOKING_URL=
# Google Calendar API — live slots in concierge (see docs/platform/google-calendar-concierge-booking.md)
# GOOGLE_CALENDAR_ENABLED=false
# GOOGLE_CALENDAR_ID=coordinator@yourdomain.com
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@....iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_BOOKING_DURATION_MINUTES=30
# GOOGLE_BOOKING_BUFFER_MINUTES=15
# GOOGLE_BOOKING_TIMEZONE=America/New_York
# GOOGLE_BOOKING_WORK_HOURS_START=09:00
# GOOGLE_BOOKING_WORK_HOURS_END=17:00
# GOOGLE_BOOKING_WORK_DAYS=1,2,3,4,5
# GOOGLE_BOOKING_HORIZON_DAYS=14
# GOOGLE_BOOKING_MIN_LEAD_HOURS=2
# Legacy aliases (optional):
# GOOGLE_BOOKINGS_CALENDAR_ID=
# GOOGLE_BOOKINGS_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_BOOKINGS_WEBHOOK_SECRET=
# N8N_GOOGLE_BOOKINGS_WEBHOOK_URL=

NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_CONTACT_EMAIL=hello@nurturecollective.com

# n8n automation webhooks (server-only)
N8N_WEBHOOK_URL=
N8N_INQUIRY_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=
N8N_TASK_SYNC_WEBHOOK_URL=
N8N_CALENDLY_WEBHOOK_URL=

# Twilio SMS — concierge webhook (server-only) + n8n intake alerts
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+18449262867
# TWILIO_PHONE_NUMBER_SID=PN848effb3e4edce45f501bfe2e97a1e97
# Public URL Twilio POSTs to (required on Amplify — must match Console webhook exactly)
# TWILIO_SMS_WEBHOOK_URL=https://dev.d9588bqvrp5xs.amplifyapp.com/api/webhooks/twilio/sms
# Local dev only — skip X-Twilio-Signature check
# TWILIO_SKIP_SIGNATURE_VALIDATION=true

# eGift cards — checkout + optional order webhook (server-only unless noted)
# GIFT_CARD_PAYMENT_PROVIDER=stub
# GIFT_CARD_ORDER_WEBHOOK_URL=
# GIFT_CARD_ORDER_WEBHOOK_SECRET=
# NEXT_PUBLIC_GIFT_CARD_PAYMENTS_ENABLED=false
# Stripe (when GIFT_CARD_PAYMENT_PROVIDER=stripe)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Billing + QuickBooks Online — purchases, invoices, n8n automation (server-only)
# BILLING_SYNC_MODE=n8n
# BILLING_PAYMENT_PROVIDER=stub
# BILLING_S3_BUCKET=
# BILLING_USE_LOCAL_STORAGE=true
# N8N_BILLING_WEBHOOK_URL=
# N8N_BILLING_WEBHOOK_SECRET=
# NEXT_PUBLIC_BILLING_PAYMENTS_ENABLED=false
# NEXT_PUBLIC_BILLING_PAYMENT_PROVIDER=stub
#
# QuickBooks OAuth + API (https://developer.intuit.com)
# QBO_ENVIRONMENT=sandbox
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# QBO_REALM_ID=
# QBO_REFRESH_TOKEN=
# QBO_REDIRECT_URI=https://your-app.example.com/api/integrations/quickbooks/oauth/callback
# QBO_WEBHOOK_VERIFIER=
# QBO_DEFAULT_ITEM_ID=
# QBO_DEFAULT_INCOME_ACCOUNT_ID=

# Calendly webhook verification (server-only)
CALENDLY_WEBHOOK_SIGNING_KEY=

# OpenAI — conversational intake (server-only)
OPENAI_API_KEY=
# Optional: defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Amplify Hosting (dev branch: https://dev.d9588bqvrp5xs.amplifyapp.com)
# Set all of these in Amplify Console → Hosting → Environment variables, then redeploy.
# amplify.yml forwards them into .env.production at build time.
#
# Required — auth
# NEXT_PUBLIC_AWS_REGION=us-east-1
# NEXT_PUBLIC_USER_POOL_ID=
# NEXT_PUBLIC_USER_POOL_CLIENT_ID=
# NEXT_PUBLIC_APP_URL=https://dev.d9588bqvrp5xs.amplifyapp.com
#
# Required — admin + S3 (attach NurtureCollectiveAmplifyComputeRole on each branch)
# TASKS_S3_BUCKET=nurture-collective-tasks
# INTAKE_S3_BUCKET=nurture-collective-tasks
# NURTURE_LEADS_BUCKET=nurture-leads-dev-886436941204
# NURTURE_EVENTS_BUCKET=nurture-events-dev-886436941204
# SERVER_AWS_ACCESS_KEY_ID=   (or use compute role IAM only)
# SERVER_AWS_SECRET_ACCESS_KEY=
# MANAGEMENT_COGNITO_GROUP=admin
# NEXT_PUBLIC_MANAGEMENT_COGNITO_GROUP=admin
#
# Public intake (dev)
# NEXT_PUBLIC_INTAKE_PUBLIC=true
# INTAKE_PUBLIC=true
#
# Concierge AI
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# Slack — see docs/platform/slack-setup.md
# SLACK_ENABLED=true
# SLACK_WEBHOOK_NEW_LEADS=
# SLACK_WEBHOOK_SCHEDULED_CALLS=
# SLACK_WEBHOOK_OPERATIONS=
# SLACK_WEBHOOK_LOST_LEADS=
#
# Booking / Calendly webhook
# NEXT_PUBLIC_CALENDLY_URL=
# CALENDLY_WEBHOOK_SIGNING_KEY=

# Google reviews — placeholder until Google Business Profile is acquired
# Visibility: off | admin (team preview) | public
NEXT_PUBLIC_GOOGLE_REVIEWS_VISIBILITY=admin
# Mode: placeholder | live (server-only; live requires keys below)
GOOGLE_REVIEWS_MODE=placeholder
# After acquisition — Google Business Profile
GOOGLE_PLACE_ID=
GOOGLE_PLACES_API_KEY=
# Optional public link for "See all reviews on Google"
NEXT_PUBLIC_GOOGLE_REVIEWS_URL=
