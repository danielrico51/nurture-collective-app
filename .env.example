# GOOGLE_TASKS_AUTH_MODE=delegated
# GOOGLE_TASKS_IMPERSONATE_SERVICE_ACCOUNT=nurture-tasks-sync@boxwood-magnet-498623-n4.iam.gserviceaccount.com
# GOOGLE_TASKS_DELEGATED_USER=admin@nesting-place.com
# GOOGLE_TASKS_LIST_TITLE=Nesting Place Tasks
# GOOGLE_TASKS_LIST_ID=
