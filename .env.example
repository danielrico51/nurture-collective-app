# Public canonical site URL for sitemap, Open Graph, and canonical links
# NEXT_PUBLIC_SITE_URL=https://www.nesting-place.com

# Temporarily block search engines (robots.txt, sitemap, noindex meta, X-Robots-Tag)
# NEXT_PUBLIC_BLOCK_SEARCH_INDEXING=true

# AWS Cognito (from `npx ampx sandbox` or Amplify console after deploy)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_USER_POOL_ID=
NEXT_PUBLIC_USER_POOL_CLIENT_ID=

# Social sign-in (Google, Facebook, Apple) — Cognito Hosted UI + identity providers
# See docs/platform/social-auth-setup.md
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_COGNITO_DOMAIN=us-east-1ruftimytf.auth.us-east-1.amazoncognito.com
# NEXT_PUBLIC_SOCIAL_AUTH_ENABLED=true
# NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=true
# NEXT_PUBLIC_AUTH_FACEBOOK_ENABLED=true
# NEXT_PUBLIC_AUTH_APPLE_ENABLED=true  # Requires Sign in with Apple in Cognito

# Dev only — allow /intake without Cognito (NEVER true in production)
# Public concierge intake without sign-in (default true). Set false to require login.
# NEXT_PUBLIC_INTAKE_PUBLIC=false
# INTAKE_PUBLIC=false

# Management task board (S3 JSON storage — legacy admin tasks + current intake migration)
TASKS_S3_BUCKET=nurture-collective-tasks

# Blog posts (JSON document in tasks bucket by default)
# BLOG_S3_BUCKET=nurture-collective-tasks
# BLOG_S3_KEY=management/blog/posts.json
# BLOG_USE_LOCAL_STORAGE=true

# Events & classes (JSON document in tasks bucket by default)
# Non-prod deployments auto-scope S3 keys so dev testing does not publish to the live catalog:
#   main  → management/events/items.json + class-registrations/
#   dev   → management/events/dev/items.json + class-registrations/dev/
#   local → .data/events/items.json
# Amplify: amplify.yml sets APP_ENV from AWS_BRANCH at build time (dev branch → dev).
# Override per branch in Amplify Console only when needed:
# APP_ENV=dev
# CLASS_REGISTRATIONS_S3_BUCKET=nurture-collective-tasks
# CLASS_REGISTRATIONS_S3_PREFIX=class-registrations/dev/
# CLASS_REGISTRATIONS_USE_LOCAL_STORAGE=true

# Class registration emails, payments, and instructor roster links
# CLASS_REGISTRATION_EMAIL_ENABLED=true
# CLASS_REGISTRATION_ADMIN_EMAIL=info@nesting-place.com
# CLASS_REGISTRATION_PROVIDER_ACCESS_SECRET=generate-a-long-random-secret
# NEXT_PUBLIC_CLASS_REGISTRATION_PAYMENTS_ENABLED=true
# NEXT_PUBLIC_CLASS_REGISTRATION_VENMO_HANDLE=@thenestingplace
# CLASS_REGISTRATION_VENMO_HANDLE=@thenestingplace
# Stripe card checkout (reuses GIFT_CARD / STRIPE_* — also enables class registration)
# Set STRIPE_SECRET_KEY + STRIPE_WEBHOOK_SECRET in Amplify Console (never commit keys).
# NEXT_PUBLIC_GIFT_CARD_PAYMENTS_ENABLED=true
# NEXT_PUBLIC_CLASS_REGISTRATION_STRIPE_ENABLED=true
# GIFT_CARD_PAYMENT_PROVIDER=stripe
# Dev webhook: https://dev.d9588bqvrp5xs.amplifyapp.com/api/webhooks/stripe (checkout.session.completed)
# Run: STRIPE_SECRET_KEY=sk_test_... ./infrastructure/aws/scripts/set-amplify-stripe-env.sh
# Classes & events Google Calendar (separate from GOOGLE_CALENDAR_ID lead-call calendar)
# CLASS_EVENTS_GOOGLE_CALENDAR_ID=c_6c4c40e2772622371ffcd13d9f51dd52474ad5f05740f10faf1d4468a272f415@group.calendar.google.com
# CLASS_EVENTS_CALENDAR_SYNC_ENABLED=true
# Google Business Profile "Book" action URL: https://www.nesting-place.com/book/classes

# Platform S3 buckets (from infrastructure/aws CloudFormation — see docs/platform/)
# NURTURE_LEADS_BUCKET=nurture-leads-dev-ACCOUNT_ID
# LEADS_USE_LOCAL_STORAGE=true   # force local .data/ lead storage
# LEADS_USE_S3=true              # opt into S3 lead storage during local dev
# NURTURE_CLIENTS_BUCKET=nurture-clients-dev-ACCOUNT_ID   # dev Amplify branch
# NURTURE_CLIENTS_BUCKET=nurture-clients-prod-ACCOUNT_ID  # main/production branch
# CLIENTS_CRM_USE_LOCAL_STORAGE=true   # force .data/nurture-clients-crm/{local|dev|prod}/
# CLIENTS_CRM_USE_S3=true              # force S3 when bucket is set (local dev against dev bucket)
# CLIENTS_CRM_S3_PREFIX=crm/staging/   # override prefix (prod default: crm/; dev: crm/dev/)
# Providers + service schedule (engagements, shifts, payouts) share this CRM prefix.
# Dev branch → crm/dev/providers/ and crm/dev/clients/.../engagements/ (isolated from prod).
# Local dev against dev bucket: APP_ENV=dev CLIENTS_CRM_USE_S3=true NURTURE_CLIENTS_BUCKET=...
# PROPOSALS_USE_LOCAL_STORAGE=true   # store proposals under .data/proposals/{local|dev}/ locally
# PROPOSALS_USE_S3=true              # force S3 against NURTURE_CLIENTS_BUCKET during local dev
# Client service invoices (branded email + Venmo/Zelle instructions)
# CLIENT_INVOICE_VENMO_HANDLE=@thenestingplace
# CLIENT_INVOICE_ZELLE_HANDLE=@thenestingplace
# CLIENT_INVOICE_ZELLE_EMAIL=thenestingplacenj@gmail.com
# CLIENT_INVOICE_ACH_BANK_NAME=Chase Bank
# CLIENT_INVOICE_ACH_ROUTING_NUMBER=021202337
# CLIENT_INVOICE_ACH_ACCOUNT_NUMBER=2910010335
# CLIENT_INVOICE_ACH_ACCOUNT_NAME=Nurture Collective LLC
# CLIENT_INVOICE_ACH_ACCOUNT_TYPE=Business Checking
# CLIENT_INVOICE_ACCESS_SECRET=generate-a-long-random-secret
#
# Client CRM outbound email (invoices, communications tab)
# Uses CLIENT_COMMS_* when set; otherwise falls back to GIFT_CARD_EMAIL_* below.
# CLIENT_COMMS_EMAIL_FROM=info@nesting-place.com
# CLIENT_COMMS_EMAIL_FROM_NAME=The Nesting Place
# CLIENT_COMMS_EMAIL_REPLY_TO=info@nesting-place.com
#
# Local dev — copy email vars from Amplify dev into .env.local:
#   ./scripts/setup-local-client-comms-env.sh
# For invoice PDF links in emails while testing locally, point at Amplify dev (not localhost):
#   NEXT_PUBLIC_APP_URL=https://dev.d9588bqvrp5xs.amplifyapp.com
# Or set manually (minimum for invoice send):
#   GIFT_CARD_EMAIL_ENABLED=true
#   GIFT_CARD_EMAIL_PROVIDER=resend
#   GIFT_CARD_EMAIL_FROM=info@nesting-place.com
#   GIFT_CARD_EMAIL_FROM_NAME=The Nesting Place
#   GIFT_CARD_EMAIL_REPLY_TO=info@nesting-place.com
#   RESEND_API_KEY=re_...
# Amplify dev/prod:
#   ./infrastructure/aws/scripts/set-amplify-gift-card-email-env.sh
#   AMPLIFY_BRANCH=dev ./infrastructure/aws/scripts/set-amplify-client-comms-env.sh
#   AMPLIFY_BRANCH=main ./infrastructure/aws/scripts/set-amplify-client-comms-env.sh
#   npm run setup:amplify-billing-sync-env
#   ./scripts/setup-local-client-comms-env.sh
# Merge checklist: docs/platform/client-crm-production-merge.md
# GOOGLE_PROPOSAL_TEMPLATE_DOC_ID=   # optional override (any environment)
# GOOGLE_PROPOSAL_TEMPLATE_DOC_ID_DEV=   # dev Amplify branch master template
# GOOGLE_PROPOSAL_TEMPLATE_DOC_ID_PROD=  # main/production master template
# GOOGLE_PROPOSAL_DRIVE_FOLDER_ID=       # optional override (any environment)
# GOOGLE_PROPOSAL_DRIVE_FOLDER_ID_DEV=1kucYlHjXwgWV7XW-oKDKqRmk9hOYNExP   # Proposals - DEV
# GOOGLE_PROPOSAL_DRIVE_FOLDER_ID_PROD=  # Proposals - PROD folder id
# PROPOSAL_LIBRARY_S3_BUCKET=        # defaults to TASKS_S3_BUCKET; library prefix is proposal-library/dev/ on dev
# PROPOSAL_LIBRARY_S3_PREFIX=        # optional override (prod default: proposal-library/)
# PROPOSAL_SIGNATURE_WEBHOOK_SECRET= # x-proposal-signature-secret header for /api/proposals/signature/webhook
# Amplify setup: AMPLIFY_BRANCH=dev ./infrastructure/aws/scripts/set-amplify-proposals-env.sh
# NURTURE_EVENTS_BUCKET=nurture-events-dev-ACCOUNT_ID
# NURTURE_CONTRACTS_BUCKET=nurture-contracts-dev-ACCOUNT_ID
# NURTURE_PROPOSALS_BUCKET=nurture-proposals-dev-ACCOUNT_ID
# NURTURE_NOTIFICATIONS_BUCKET=nurture-notifications-dev-ACCOUNT_ID
# NURTURE_ANALYTICS_BUCKET=nurture-analytics-dev-ACCOUNT_ID

# Django platform API (backend/) — optional in Sprint 1
# PLATFORM_API_URL=http://localhost:8000/api/v1

# Community service (community-service/) — member app proxy (server-side)
COMMUNITY_API_URL=http://localhost:8001
# Post feed scope: dev | staging | production (use dev locally so test posts stay off prod)
COMMUNITY_ENV_SCOPE=dev
NEXT_PUBLIC_COMMUNITY_ENV_SCOPE=dev
# Browser WebSocket base (optional; defaults to localhost:8001 in dev)
# NEXT_PUBLIC_COMMUNITY_API_URL=http://localhost:8001
# Set to false to disable example communities when the service is offline
# COMMUNITY_DEMO_FALLBACK=false
# Community media (post images + profile avatars):
#   - Local dev: stored under .data/ (served via /api/community/media/… and /api/account/avatar/…)
#   - Production: set an S3 bucket below (falls back to TASKS_S3_BUCKET if unset)
# COMMUNITY_MEDIA_S3_BUCKET=nurture-collective-tasks
# Post photos are stored under .data/community-post-images/ in local dev (served via /api/community/media/…)
# community-service/.env must use the same pool/client when validating Cognito:
#   COGNITO_USER_POOL_ID=${NEXT_PUBLIC_USER_POOL_ID}
#   COGNITO_USER_POOL_CLIENT_ID=${NEXT_PUBLIC_USER_POOL_CLIENT_ID}
#   JWT_DEV_BYPASS=true   # local only

# Member intake profiles (partitioned S3 JSON — defaults to local .data/ in dev)
# INTAKE_S3_BUCKET=nurture-collective-tasks
# Intake partition layout:
#   management/process=intake/user=<cognito-sub>/status=<status>/intake.json
# Conversation partition layout:
#   management/process=conversation/user=<cognito-sub>/session=<session-id>/conversation.json
# Legacy aggregate index (dual-written for backwards compatibility):
#   management/intake.json
# INTAKE_USE_LOCAL_STORAGE=true
# Set INTAKE_LEGACY_INDEX=false to stop updating management/intake.json
# Optional: defaults to management/tasks.json
# TASKS_S3_KEY=management/tasks.json
# Optional: defaults to admin if unset
MANAGEMENT_COGNITO_GROUP=admin
# Required at build time for client nav gating (must match MANAGEMENT_COGNITO_GROUP)
NEXT_PUBLIC_MANAGEMENT_COGNITO_GROUP=admin

# Amplify SSR server credentials (custom names — Amplify blocks AWS_* prefix)
# Create an IAM user with S3 + Cognito ListUsers, then set in Amplify env + .env.local
# SERVER_AWS_ACCESS_KEY_ID=
# SERVER_AWS_SECRET_ACCESS_KEY=

# Booking / scheduling — provider: auto | calendly | google
NEXT_PUBLIC_BOOKING_PROVIDER=google
# Calendly (legacy fallback — leave empty when using Google)
NEXT_PUBLIC_CALENDLY_URL=
# Google Workspace appointment schedule embed (optional override; app has a default)
