# QBO_ENVIRONMENT=sandbox   # use production for live QBO companies
# QBO_CLIENT_ID=
# QBO_CLIENT_SECRET=
# Production redirect (main): https://main.d9588bqvrp5xs.amplifyapp.com/api/integrations/quickbooks/oauth/callback
# Dev redirect (if testing prod keys on dev): https://dev.d9588bqvrp5xs.amplifyapp.com/api/integrations/quickbooks/oauth/callback
