{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "LeadsReadWrite",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::nurture-leads-ENV-ACCOUNT_ID",
        "arn:aws:s3:::nurture-leads-ENV-ACCOUNT_ID/*"
      ]
    },
    {
      "Sid": "EventsAppend",
      "Effect": "Allow",
      "Action": ["s3:PutObject", "s3:GetObject", "s3:ListBucket"],
      "Resource": [
        "arn:aws:s3:::nurture-events-ENV-ACCOUNT_ID",
        "arn:aws:s3:::nurture-events-ENV-ACCOUNT_ID/*"
      ]
    },
    {
      "Sid": "TasksAndIntakeS3Objects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": "arn:aws:s3:::nurture-collective-tasks/*"
    },
    {
      "Sid": "TasksAndIntakeS3List",
      "Effect": "Allow",
      "Action": "s3:ListBucket",
      "Resource": "arn:aws:s3:::nurture-collective-tasks",
      "Condition": {
        "StringLike": {
          "s3:prefix": ["management/*", "platform/*"]
        }
      }
    },
    {
      "Sid": "CognitoListUsers",
      "Effect": "Allow",
      "Action": ["cognito-idp:ListUsers", "cognito-idp:ListUsersInGroup"],
      "Resource": "arn:aws:cognito-idp:REGION:ACCOUNT_ID:userpool/USER_POOL_ID"
    },
    {
      "Sid": "SESSendGiftCards",
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:SendRawEmail"],
      "Resource": "*"
    }
  ]
}
