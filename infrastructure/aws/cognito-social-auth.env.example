# Copy to cognito-social-auth.env (gitignored) and fill in values from
# Google Cloud, Meta, and Apple Developer consoles.
# Then run: ./infrastructure/aws/configure-cognito-social-auth.sh

AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_rUfTimytf
COGNITO_APP_CLIENT_ID=4t0uapt8havig5h7jiio9g9os4
COGNITO_HOSTED_UI_DOMAIN=us-east-1ruftimytf.auth.us-east-1.amazoncognito.com

# Register this redirect URI in each IdP console:
# https://us-east-1ruftimytf.auth.us-east-1.amazoncognito.com/oauth2/idpresponse

# Google Cloud → APIs & Services → Credentials → OAuth 2.0 Web client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta → Facebook Login → Settings
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Apple → Sign in with Apple → Services ID + Key (.p8)
SIWA_CLIENT_ID=
SIWA_TEAM_ID=
SIWA_KEY_ID=
# Path to AuthKey_XXXX.p8 (preferred) or inline key with \n for newlines
SIWA_PRIVATE_KEY_FILE=
