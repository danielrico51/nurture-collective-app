{
  "name": "nurture-collective-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.8.1"
  },
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=6144' next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:gift-card-email": "tsx scripts/send-gift-card-email-sample.ts",
    "resend:gift-card-email": "tsx scripts/resend-gift-card-email.ts",
    "migrate:tasks-to-google": "tsx scripts/migrate-tasks-to-google.ts",
    "reset:migrate:google-tasks": "tsx scripts/reset-and-migrate-google-tasks.ts",
    "google-tasks:oauth-setup": "tsx scripts/google-tasks-oauth-setup.ts",
    "list:google-tasks": "tsx scripts/list-google-task-lists.ts",
    "import:legacy-blog": "tsx scripts/import-legacy-blog.ts",
    "sync:legacy-blog": "tsx scripts/sync-legacy-blog-to-storage.ts",
    "sync:coverage": "tsx scripts/sync-coverage-to-storage.ts",
    "setup:personal-google-tasks": "bash infrastructure/google/setup-personal-tasks-sync.sh",
    "setup:concierge-scheduling": "bash infrastructure/google/setup-concierge-scheduling.sh",
    "verify:calendar-deploy": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/verify-calendar-deploy-credentials.ts",
    "verify:proposal-docs": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/verify-proposal-docs-credentials.ts",
    "setup:proposal-google-template": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/create-proposal-google-template.ts",
    "update:proposal-google-template": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/update-proposal-google-template.ts",
    "migrate:clients": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/migrate-proposals-to-clients.ts",
    "setup:proposal-docs": "bash infrastructure/google/setup-proposal-docs.sh",
    "test:calendar-delegation": "tsx scripts/test-google-calendar-delegation.ts",
    "amplify:concierge-scheduling": "bash infrastructure/aws/scripts/set-amplify-google-calendar-env.sh",
    "setup:cognito-google": "bash infrastructure/google/setup-cognito-google-oauth.sh",
    "setup:cognito-federated-presignup": "bash infrastructure/aws/scripts/deploy-cognito-federated-presignup.sh",
    "setup:cognito-resend-email": "bash infrastructure/aws/scripts/deploy-cognito-resend-email.sh",
    "setup:cognito-clients-group": "bash infrastructure/aws/scripts/deploy-cognito-post-confirmation-clients-group.sh",
    "setup:local-client-comms-env": "bash scripts/setup-local-client-comms-env.sh",
    "setup:amplify-client-comms-env": "bash infrastructure/aws/scripts/set-amplify-client-comms-env.sh",
    "setup:amplify-billing-sync-env": "bash infrastructure/aws/scripts/set-amplify-billing-sync-env.sh",
    "setup:google-wif": "bash infrastructure/google/setup-workload-identity-federation.sh",
    "amplify:google-wif": "bash infrastructure/aws/scripts/set-amplify-google-wif-env.sh",
    "share:intro-calendar": "bash infrastructure/google/share-intro-calendar-with-sa.sh",
    "seed:providers": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/seed-providers-from-schedule-html.ts",
    "seed:providers:roster": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/seed-active-providers-roster.ts",
    "import:birth-schedule": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/import-birth-doula-schedule.ts",
    "import:postpartum-schedule": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/import-postpartum-doula-schedule.ts",
    "rebuild:dashboard-snapshot": "NODE_OPTIONS='-r ./scripts/lib/server-only-stub.cjs' tsx scripts/rebuild-dashboard-snapshot.ts"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.0.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1053.0",
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/client-ses": "^3.1060.0",
    "@aws-sdk/s3-request-presigner": "^3.1059.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "aws-amplify": "^6.0.0",
    "aws-jwt-verify": "^5.1.1",
    "driver.js": "^1.4.0",
    "googleapis": "^173.0.0",
    "leaflet": "^1.9.4",
    "next": "13.4.19",
    "next-themes": "^0.3.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-leaflet": "^4.2.1",
    "server-only": "^0.0.1",
    "stripe": "^17.7.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.14.3",
    "@aws-amplify/backend-cli": "^1.3.0",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.27",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.0.1",
    "aws-cdk": "^2",
    "aws-cdk-lib": "^2",
    "constructs": "^10.3.0",
    "esbuild": "^0.23.1",
    "eslint": "^8",
    "eslint-config-next": "13.4.19",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
